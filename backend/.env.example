# MediGuide Backend Environment Variables
# Copy this to .env and fill in your values

# LLM Providers (at least one required)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Optional fallbacks
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
GOOGLE_API_KEY=your_google_gemini_key_here
GOOGLE_MODEL=gemini-1.5-flash
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat

# Security
JWT_SECRET=replace_with_a_random_32+_char_secret
ALLOWED_ORIGIN=https://mediguide.app,https://www.mediguide.app

# Server
PORT=5000
NODE_ENV=production

# Production configuration
PRIMARY_PROVIDER=groq

# Database Settings
DB_HOST=mysql
DB_USER=mediguide
DB_PASSWORD=your_secure_password_here
DB_NAME=mediguidedb

# OpenTelemetry Tracing (optional — leave empty for local dev)
# Set to your Jaeger/Tempo/OTLP collector endpoint in production
# OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger-collector:4318
